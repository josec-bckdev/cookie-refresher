# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7
AGENT_MAX_STEPS=20

# ── VNC browser sandbox ───────────────────────────────────────────────────────
# URL of the VNC container that exposes the browser HTTP control API
VNC_BROWSER_URL=http://vnc-browser:8080

# ── vtrack FastAPI ────────────────────────────────────────────────────────────
VTRACK_API_URL=http://api:8000

# For local dev (outside Docker):
# VTRACK_API_URL=http://localhost:8000

# ── Login credentials ─────────────────────────────────────────────────────────
LOGIN_EMAIL=your_email@example.com
LOGIN_PASSWORD=your_password_here

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULE_MORNING=0 6 * * 1-5
SCHEDULE_AFTERNOON=0 15 * * 1-5
TIMEZONE=America/Bogota

# ── Service ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
